@model IEnumerable<Employee>
@{ 
    Layout = "_Layout";
}

<table>
    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Department</th>
    </tr>
    <tbody>
        @foreach(Employee m in Model)
        {
            <tr>
                <td>@m.Name</td>
                <td>@m.Email</td>
                <td>@m.Email</td>
            </tr>
        }
    </tbody>
</table>
    